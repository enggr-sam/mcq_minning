# Optional: full API base URL used by the app (e.g. in production or when not using the dev proxy).
# Example: https://api.example.com/api/v1
# VITE_API_URL=

# Optional: backend URL for Vite dev server proxy (only affects npm run dev).
# Default: http://127.0.0.1:8000
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001
